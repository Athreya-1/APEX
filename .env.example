# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role (server-only; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — AI routes (/api/ai, quick-add, goals/decompose, knowledge)
ANTHROPIC_API_KEY=

# App URL — must match your Vercel deployment (e.g. https://apex.vercel.app)
NEXT_PUBLIC_APP_URL=

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional model overrides (defaults shown)
# APEX_MODEL_HAIKU=claude-haiku-4-5
# APEX_MODEL_SONNET=claude-sonnet-4-5
